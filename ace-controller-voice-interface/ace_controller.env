# API Keys
NGC_API_KEY=nvapi-
NVIDIA_API_KEY=nvapi-

# config file path
CONFIG_PATH=./configs/config_riva_public_endpoints.yaml

# Timeout threshold for sending a request to the FastAPI server
REQUEST_TIMEOUT=15.0

# Optional WebRTC TURN (required for many NAT / K8s deployments). Match UI build VITE_TURN_*.
# For OpenShift deploy: source this file before ./deploy/deploy-app.sh so TURN_* and keys are in the environment.
# TURN_SERVER_URL=turn:your-host:3478
# TURN_USERNAME=
# TURN_PASSWORD=

# Optional Metered: server-side key; browser uses GET /ice_config (see config.ts fetchRtcConfigFromPipeline).
# METERED_TURN_API_KEY=
# METERED_CREDENTIALS_URL=https://fax.metered.live/api/v1/turn/credentials