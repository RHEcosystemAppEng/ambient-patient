# Copy to deploy/turn-overrides.yaml and fill in Metered (or coturn) static relay credentials
# for the ace-controller-pipeline pod. This file is gitignored.
#
#   cp deploy/turn-overrides.yaml.example deploy/turn-overrides.yaml
#   # edit deploy/turn-overrides.yaml
#   ./deploy/deploy-app.sh
#
# Metered dashboard → TURN / credentials (URL, username, password for the server peer).

aceControllerPipeline:
  turnServerUrl: "turn:global.relay.metered.ca:80"
  turnUsername: "REPLACE_ME"
  turnPassword: "REPLACE_ME"
